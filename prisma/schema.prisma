generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Settings {
  id          String  @id @default("global")
  companyName String  @default("Moura")
  ownerName   String  @default("Nivaldo Moura Da Silva")
  publicLang  String  @default("it")
  phone       String  @default("328 064 2160")
  email       String  @default("")
  address     String  @default("Via Piacenza, 2 - Limbiate (MB)")
  vatNumber   String  @default("IT05142890960")
  instagram   String  @default("")
  facebook    String  @default("")
  whatsapp    String  @default("3280642160")

  @@map("settings")
}

model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  address     String
  serviceType String
  description String
  budget      String?
  status      String   @default("nuovo")
  notes       String?
  lang        String   @default("it")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("quote_requests")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  lang      String   @default("it")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model Media {
  id        String   @id @default(cuid())
  type      String   // "photo" | "video"
  title     String   @default("")
  url       String   // base64 para foto, link para video
  thumbnail String?  // thumbnail do video
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("media")
}
